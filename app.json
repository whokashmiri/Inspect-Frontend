{
  "expo": {
    "name": "ValueTech",
    "slug": "batchcam",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "batchcam",
     "icon": "./assets/Logo.png",
    "splash": {
      "backgroundColor": "#8AA39B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.batchcam",
      "infoPlist": {
        "NSCameraUsageDescription": "BatchCam needs camera access to capture photos",
        "NSPhotoLibraryAddUsageDescription": "BatchCam needs access to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo.png",
        "backgroundColor": "#ffffff"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.anonymous.batchcam"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "BatchCam needs camera access to take photos in batches."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "BatchCam needs camera access to capture photos"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "BatchCam needs access to save photos to your library.",
          "savePhotosPermission": "BatchCam needs access to save photos to your library.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "react-native-vision-camera",
      "expo-secure-store",
      "expo-font",
      "expo-sqlite",
      "expo-audio",
      "expo-router",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "427a0f48-8299-47a2-8452-068726cbd2a2"
      }
    }
  }
}
